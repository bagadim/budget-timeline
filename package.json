{
  "name": "budget-timeline",
  "version": "0.0.0",
  "private": true,
  "description": "Personal budget tracker with timeline view and planned milestones.",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev-kill": "kill -9 $(lsof -tiTCP:4000,4001 -sTCP:LISTEN) 2>/dev/null || echo 'no dev processes on :4000/:4001'",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @budget-timeline/db db:generate",
    "db:migrate": "pnpm --filter @budget-timeline/db db:migrate",
    "db:studio": "pnpm --filter @budget-timeline/db db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
